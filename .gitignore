# Virtual environment
venv/
.venv/

# Python cache and test artifacts
__pycache__/
*.py[cod]
.pytest_cache/

# Build artifacts and application logs
build/
dist/
*.spec
logs/

# Real operational data - NEVER commit these
data/raw/*
data/output/*
shared_workspace/

# Keep folder structure but ignore contents
!data/raw/.gitkeep
!data/output/.gitkeep

# Environment variables (if any credentials are added later)
.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
